<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- 1. Route API requests to Node.js Backend -->
                <rule name="ReverseProxy_API" stopProcessing="true">
                    <match url="^api/(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:3000/api/{R:1}" />
                </rule>

                <!-- 2. Route Uploads to Node.js Backend -->
                <rule name="ReverseProxy_Uploads" stopProcessing="true">
                    <match url="^uploads/(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:3000/uploads/{R:1}" />
                </rule>

                <!-- 3. Route Admin Frontend -->
                <rule name="ReverseProxy_Admin" stopProcessing="true">
                    <match url="^admin/(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:5175/ocsc-circular/admin/{R:1}" />
                </rule>

                <!-- 4. Route Public Frontend -->
                <rule name="ReverseProxy_Public" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:5173/ocsc-circular/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
